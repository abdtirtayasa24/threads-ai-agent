# Database
DATABASE_URL=sqlite:///./threads_agent.db
# For use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/threads_db

# AI Provider
AI_API_KEY=your-ai-api-key
AI_MODEL=your-ai-model
OPENROUTER_API_KEY=your-openrouter-api-key
IMAGE_MODEL=your-image-ai-model

# Telegram Approval Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
WEBHOOK_URL=https://your-domain.com/api/approval/webhook

# Threads API
THREADS_USER_ID=your-threads-user-id
THREADS_ACCESS_TOKEN=your-threads-access-token

# App Settings
AUTO_PUBLISH=false
GENERATE_ILLUSTRATIONS=true
BASE_URL=https://your-domain.com